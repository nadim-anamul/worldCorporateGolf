# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=wcc
DB_USER=root
DB_PASS=

# SSL Commerz Credentials (use sandbox values for local development)
SSL_STORE_ID=your_store_id
SSL_STORE_PASSWORD=your_store_password
SSL_IS_SANDBOX=true

# Application Settings
APP_BASE_URL=http://localhost:8000

# Admin Panel Credentials
ADMIN_USER=change_me
ADMIN_PASS=change_me_to_a_strong_password

# Tournament Information (Used when database tournament is unavailable)
EVENT_NAME="Golf Tournament"
EVENT_DATE="TBA"
EVENT_VENUE="TBA"
EVENT_FORMAT="Stableford (Shotgun Start)"
EVENT_DEADLINE="TBA"
EVENT_FEE=2000
EVENT_CURRENCY=BDT
CONTACT_PHONE_1=""
CONTACT_PHONE_2=""

# SMS API Configuration (bdbulksms)
SMS_API_URL="https://api.bdbulksms.net/api.php?json"
SMS_API_TOKEN="your_sms_api_token"
SMS_MESSAGE_TEMPLATE="Dear %PLAYER_NAME%, your %EVENT_NAME% registration is confirmed. Preferred time: %TEE_TIME%. Please arrive 30 minutes early. - GolfHouse"
